<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="400.0" prefWidth="400.0" spacing="15.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.gabriel.twoforms.AdminController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
    <Label styleClass="header-label" text="Admin Dashboard" />
    <Button mnemonicParsing="false" onAction="#goToCreateAccount" prefWidth="250.0" styleClass="primary-button" text="Create Account" />
    <Button mnemonicParsing="false" onAction="#goToViewAccounts" prefWidth="250.0" styleClass="secondary-button" text="View All Accounts" />
    <Button mnemonicParsing="false" onAction="#goToModifyAccount" prefWidth="250.0" styleClass="secondary-button" text="Modify Account" />
    <Button mnemonicParsing="false" onAction="#goToDeleteAccount" prefWidth="250.0" styleClass="secondary-button" text="Delete Account" />
    <Button mnemonicParsing="false" onAction="#logout" prefWidth="250.0" styleClass="secondary-button" text="Logout" />
</VBox>