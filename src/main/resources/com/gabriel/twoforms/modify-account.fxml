<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<StackPane prefHeight="400.0" prefWidth="540.0" styleClass="background-pane" stylesheets="@style.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.gabriel.twoforms.ModifyAccountController">
   <children>
      <VBox alignment="CENTER" maxWidth="440.0" prefHeight="366.0" prefWidth="440.0" spacing="15.0" styleClass="front-card">
          <padding>
              <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
          </padding>
         <HBox alignment="TOP_CENTER" prefHeight="80.0" prefWidth="398.0">
            <children>
               <ImageView fitHeight="90.0" fitWidth="100.0" pickOnBounds="true" preserveRatio="true">
                  <image>
                     <Image url="@images/pagibig.jpg" />
                  </image>
               </ImageView>
               <VBox alignment="CENTER_LEFT" prefHeight="106.0" prefWidth="322.0">
                  <children>
                      <Label prefHeight="48.0" prefWidth="217.0" styleClass="bold-text" text="Modify Account" />
                     <Label text="Update account holder details" />
                  </children>
               </VBox>
            </children>
         </HBox>
      
          <Label fx:id="messageLabel" styleClass="label" textFill="#0066FF" />
         <GridPane hgap="14.0" prefHeight="107.0" prefWidth="398.0" vgap="12.0">
           <columnConstraints>
             <ColumnConstraints hgrow="SOMETIMES" maxWidth="187.0" minWidth="10.0" prefWidth="143.0" />
             <ColumnConstraints hgrow="SOMETIMES" maxWidth="241.0" minWidth="10.0" prefWidth="241.0" />
           </columnConstraints>
           <rowConstraints>
             <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
             <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
           </rowConstraints>
            <children>
            
                <TextField fx:id="accNumField" maxWidth="250" prefHeight="40.0" prefWidth="202.0" promptText="Enter Account Number" styleClass="text-field" GridPane.columnIndex="1" />
                <TextField fx:id="newOwnerField" maxWidth="250" promptText="Enter New Owner Name" styleClass="text-field" GridPane.columnIndex="1" GridPane.rowIndex="1" />
               <Label alignment="CENTER_RIGHT" prefHeight="18.0" prefWidth="160.0" text="Account Number" />
               <Label alignment="TOP_RIGHT" contentDisplay="RIGHT" prefHeight="18.0" prefWidth="163.0" text="Owner Name" GridPane.rowIndex="1" />
            </children>
         </GridPane>
         <HBox alignment="CENTER_RIGHT" prefHeight="30.0" prefWidth="398.0" spacing="18.0">
            <children>
                <Button mnemonicParsing="false" onAction="#goBack" prefHeight="38.0" prefWidth="91.0" styleClass="secondary-button" text="Back" />
            
                <Button mnemonicParsing="false" onAction="#handleModify" prefHeight="38.0" prefWidth="90.0" styleClass="primary-button" text="Update" />
            </children>
         </HBox>
      </VBox>
   </children>
   <padding>
      <Insets bottom="28.0" left="28.0" right="28.0" top="28.0" />
   </padding>
</StackPane>
