<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="300.0" prefWidth="400.0" spacing="15.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.gabriel.twoforms.DeleteAccountController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
    <Label styleClass="header-label" text="Delete Account" />

    <TextField fx:id="accNumField" maxWidth="250" promptText="Enter Account Number" styleClass="text-field" />

    <Label fx:id="messageLabel" styleClass="label" textFill="red" />

    <Button mnemonicParsing="false" onAction="#handleDelete" prefWidth="250.0" style="-fx-background-color: #DC3545; -fx-text-fill: white;" styleClass="primary-button" text="Delete Account" />
    <Button mnemonicParsing="false" onAction="#goBack" prefWidth="250.0" styleClass="secondary-button" text="Back to Dashboard" />
</VBox>