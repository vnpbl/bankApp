<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<StackPane prefHeight="360.0" prefWidth="520.0" styleClass="background-pane" stylesheets="@style.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.gabriel.twoforms.CreateAccountController">
   <children>
      <VBox prefHeight="236.0" prefWidth="605.0" spacing="18.0" styleClass="front-card">
         <children>
            <HBox prefHeight="66.0" prefWidth="402.0">
               <children>
                  <ImageView fitHeight="90.0" fitWidth="100.0" pickOnBounds="true" preserveRatio="true">
                     <image>
                        <Image url="@images/pagibig.jpg" />
                     </image>
                  </ImageView>
                  <VBox alignment="CENTER_LEFT" prefHeight="61.0" prefWidth="382.0">
                     <children>
                        <Label styleClass="bold-text" text="Create Account" />
                        <Label styleClass="screen-subtitle" text="Add a new customer banking profile" />
                     </children>
                  </VBox>
               </children>
            </HBox>
            <GridPane hgap="14.0" prefHeight="88.0" prefWidth="402.0" vgap="12.0">
              <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" maxWidth="212.0" minWidth="10.0" prefWidth="182.0" />
                <ColumnConstraints hgrow="SOMETIMES" maxWidth="206.0" minWidth="10.0" prefWidth="206.0" />
              </columnConstraints>
              <rowConstraints>
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
              </rowConstraints>
               <children>
                  <TextField fx:id="acc_num" prefHeight="26.0" prefWidth="60.0" GridPane.columnIndex="1" />
                  <Label text="Enter owner name" GridPane.rowIndex="1" />
                  <TextField fx:id="tf_name" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                  <Label text="Account Number" />
               </children>
            </GridPane>
            <HBox alignment="CENTER_RIGHT" prefHeight="32.0" prefWidth="402.0" spacing="18.0">
               <children>
                  <Button mnemonicParsing="false" onAction="#goBack" prefHeight="57.0" prefWidth="79.0" styleClass="menu-button" text="Back" />
                  <Button fx:id="createSubmit" alignment="CENTER_RIGHT" mnemonicParsing="false" onAction="#OnCreateSubmit" prefHeight="27.0" prefWidth="89.0" styleClass="primary-button" text="Submit" />
               </children>
            </HBox>
         </children>
         <padding>
            <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
         </padding>
      </VBox>
   </children>
   <padding>
      <Insets bottom="28.0" left="28.0" right="28.0" top="28.0" />
   </padding>
</StackPane>
